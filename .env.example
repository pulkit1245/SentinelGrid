# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sentinelgrid:password@localhost:5432/sentinelgrid
DATABASE_SYNC_URL=postgresql://sentinelgrid:password@localhost:5432/sentinelgrid

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Service Auth ─────────────────────────────────────────────────────────────
SERVICE_TOKEN=internal-service-token-change-in-production

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ── Mapbox ────────────────────────────────────────────────────────────────────
MAPBOX_TOKEN=your-mapbox-public-token

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_API_KEY=your-claude-or-openai-api-key

# ── Object Storage (MinIO / S3) ───────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sentinelgrid-evidence

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
ENVIRONMENT=development

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
