{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AlertObject",
  "type": "object",
  "required": ["id", "zone_id", "severity", "graph_path", "triggered_at", "is_active"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "zone_id": { "type": "string", "format": "uuid" },
    "zone_name": { "type": "string" },
    "severity": { "type": "string", "enum": ["info", "watch", "warning", "critical"] },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "graph_path": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "node": { "type": "string" },
          "rel": { "type": "string" },
          "next": { "type": "string" },
          "value": { "type": "number" },
          "threshold": { "type": "number" }
        }
      }
    },
    "triggered_at": { "type": "string", "format": "date-time" },
    "confirmed_by": { "type": ["string", "null"], "format": "uuid" },
    "confirmed_at": { "type": ["string", "null"], "format": "date-time" },
    "is_active": { "type": "boolean" },
    "evidence_snapshot_id": { "type": ["string", "null"], "format": "uuid" }
  }
}
