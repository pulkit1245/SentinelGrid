{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CVDetectionEvent",
  "type": "object",
  "required": ["zone_id", "event_type", "confidence", "frame_timestamp"],
  "properties": {
    "zone_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["ppe_violation", "zone_intrusion", "occupancy_update"] },
    "worker_track_id": { "type": "string" },
    "worker_count": { "type": "integer", "minimum": 0 },
    "ppe_violation": { "type": "boolean" },
    "ppe_details": {
      "type": "object",
      "properties": {
        "missing": { "type": "array", "items": { "type": "string" } },
        "present": { "type": "array", "items": { "type": "string" } }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "frame_timestamp": { "type": "string", "format": "date-time" },
    "snapshot_s3_key": { "type": "string" }
  }
}
