{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PermitEvent",
  "type": "object",
  "required": ["event_type", "permit_id", "zone_id", "permit_type", "issued_to_worker_id", "valid_from", "valid_to", "status", "timestamp"],
  "properties": {
    "event_type": { "type": "string", "enum": ["permit_created", "permit_revoked", "permit_expired"] },
    "permit_id": { "type": "string", "format": "uuid" },
    "zone_id": { "type": "string", "format": "uuid" },
    "permit_type": { "type": "string", "enum": ["hot_work", "confined_space", "excavation", "electrical"] },
    "issued_to_worker_id": { "type": "string", "format": "uuid" },
    "valid_from": { "type": "string", "format": "date-time" },
    "valid_to": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["active", "closed", "revoked"] },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
